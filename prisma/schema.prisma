generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  customer

  @@map("user_role")
}

enum UserStatus {
  active
  disabled

  @@map("user_status")
}

enum ProductStatus {
  draft
  published
  archived

  @@map("product_status")
}

enum CartStatus {
  active
  converted
  abandoned
  expired

  @@map("cart_status")
}

enum OrderStatus {
  pending
  awaiting_payment
  paid
  failed
  cancelled
  refunded

  @@map("order_status")
}

enum PaymentProvider {
  toyyibpay

  @@map("payment_provider")
}

enum PaymentStatus {
  created
  pending
  paid
  failed
  expired
  cancelled

  @@map("payment_status")
}

enum EntitlementStatus {
  active
  revoked
  expired

  @@map("entitlement_status")
}

enum EventSource {
  system
  return_url
  callback_url
  manual_admin

  @@map("event_source")
}

model AppUser {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                String                 @unique @db.Citext
  passwordHash         String?                @map("password_hash")
  fullName             String                 @map("full_name")
  phoneNumber          String?                @map("phone_number")
  role                 UserRole               @default(customer)
  status               UserStatus             @default(active)
  emailVerifiedAt      DateTime?              @map("email_verified_at") @db.Timestamptz(6)
  lastLoginAt          DateTime?              @map("last_login_at") @db.Timestamptz(6)
  createdAt            DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  carts                Cart[]
  orders               Order[]
  entitlements         DownloadEntitlement[]
  adminAuditLogs       AdminAuditLog[]        @relation("AdminAuditLogs")
  createdProducts      Product[]              @relation("ProductsCreatedBy")
  updatedProducts      Product[]              @relation("ProductsUpdatedBy")

  @@map("app_users")
}

model Category {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String    @unique
  description String?
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  products    Product[]

  @@map("categories")
}

model Tag {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String       @unique
  slug      String       @unique
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  products  ProductTag[]

  @@map("tags")
}

model Product {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId       String         @map("category_id") @db.Uuid
  name             String
  slug             String         @unique
  shortDescription String?        @map("short_description")
  description      String
  priceCents       Int            @map("price_cents")
  currencyCode     String         @default("MYR") @map("currency_code") @db.Char(3)
  status           ProductStatus  @default(draft)
  previewImagePath String?        @map("preview_image_path")
  createdById      String?        @map("created_by") @db.Uuid
  updatedById      String?        @map("updated_by") @db.Uuid
  publishedAt      DateTime?      @map("published_at") @db.Timestamptz(6)
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  category         Category       @relation(fields: [categoryId], references: [id])
  createdBy        AppUser?       @relation("ProductsCreatedBy", fields: [createdById], references: [id])
  updatedBy        AppUser?       @relation("ProductsUpdatedBy", fields: [updatedById], references: [id])
  assets           ProductAsset[]
  cartItems        CartItem[]
  orderItems       OrderItem[]
  tags             ProductTag[]

  @@index([status, categoryId], map: "idx_products_status_category")
  @@index([publishedAt], map: "idx_products_published_at")
  @@map("products")
}

model ProductTag {
  productId  String   @map("product_id") @db.Uuid
  tagId      String   @map("tag_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@map("product_tags")
}

model ProductAsset {
  id             String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId      String                   @map("product_id") @db.Uuid
  fileName       String                   @map("file_name")
  storagePath    String                   @unique @map("storage_path")
  mimeType       String                   @map("mime_type")
  fileSizeBytes  BigInt                   @map("file_size_bytes")
  checksumSha256 String?                  @map("checksum_sha256")
  versionLabel   String                   @default("v1") @map("version_label")
  sortOrder      Int                      @default(0) @map("sort_order")
  isActive       Boolean                  @default(true) @map("is_active")
  createdAt      DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  product        Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)
  downloadLogs   EntitlementDownloadLog[]

  @@index([productId], map: "idx_product_assets_product_id")
  @@map("product_assets")
}

model Cart {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appUserId    String?     @map("app_user_id") @db.Uuid
  sessionToken String      @unique @default(dbgenerated("gen_random_uuid()")) @map("session_token") @db.Uuid
  status       CartStatus  @default(active)
  currencyCode String      @default("MYR") @map("currency_code") @db.Char(3)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  convertedAt  DateTime?   @map("converted_at") @db.Timestamptz(6)
  appUser      AppUser?    @relation(fields: [appUserId], references: [id])
  items        CartItem[]
  orders       Order[]

  @@index([appUserId], map: "idx_carts_app_user_id")
  @@map("carts")
}

model CartItem {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cartId         String   @map("cart_id") @db.Uuid
  productId      String   @map("product_id") @db.Uuid
  quantity       Int      @default(1)
  unitPriceCents Int      @map("unit_price_cents")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  cart           Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@map("cart_items")
}

model Order {
  id             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  publicOrderNo  String                @unique @map("public_order_no")
  appUserId      String?               @map("app_user_id") @db.Uuid
  cartId         String?               @map("cart_id") @db.Uuid
  buyerFullName  String                @map("buyer_full_name")
  buyerEmail     String                @map("buyer_email") @db.Citext
  buyerPhone     String?               @map("buyer_phone")
  status         OrderStatus           @default(pending)
  currencyCode   String                @default("MYR") @map("currency_code") @db.Char(3)
  subtotalCents  Int                   @map("subtotal_cents")
  totalCents     Int                   @map("total_cents")
  notes          String?
  paidAt         DateTime?             @map("paid_at") @db.Timestamptz(6)
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  appUser        AppUser?              @relation(fields: [appUserId], references: [id])
  cart           Cart?                 @relation(fields: [cartId], references: [id])
  items          OrderItem[]
  payment        Payment?
  entitlements   DownloadEntitlement[]

  @@index([buyerEmail], map: "idx_orders_buyer_email")
  @@index([status, createdAt], map: "idx_orders_status_created_at")
  @@map("orders")
}

model OrderItem {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId             String                @map("order_id") @db.Uuid
  productId           String                @map("product_id") @db.Uuid
  productNameSnapshot String                @map("product_name_snapshot")
  productSlugSnapshot String                @map("product_slug_snapshot")
  quantity            Int                   @default(1)
  unitPriceCents      Int                   @map("unit_price_cents")
  lineTotalCents      Int                   @map("line_total_cents")
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  order               Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product             Product               @relation(fields: [productId], references: [id])
  entitlements        DownloadEntitlement[]

  @@index([orderId], map: "idx_order_items_order_id")
  @@map("order_items")
}

model Payment {
  id                    String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId               String          @unique @map("order_id") @db.Uuid
  provider              PaymentProvider @default(toyyibpay)
  status                PaymentStatus   @default(created)
  providerBillCode      String?         @unique @map("provider_bill_code")
  providerTransactionId String?         @map("provider_transaction_id")
  providerReference1    String?         @map("provider_reference_1")
  providerReference2    String?         @map("provider_reference_2")
  amountCents           Int             @map("amount_cents")
  currencyCode          String          @default("MYR") @map("currency_code") @db.Char(3)
  paymentUrl            String?         @map("payment_url")
  initiatedAt           DateTime?       @map("initiated_at") @db.Timestamptz(6)
  paidAt                DateTime?       @map("paid_at") @db.Timestamptz(6)
  rawLastPayload        Json?           @map("raw_last_payload") @db.JsonB
  createdAt             DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  order                 Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events                PaymentEvent[]

  @@index([status], map: "idx_payments_status")
  @@map("payments")
}

model PaymentEvent {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentId        String      @map("payment_id") @db.Uuid
  source           EventSource
  providerEventName String     @map("provider_event_name")
  payloadJson      Json        @map("payload_json") @db.JsonB
  payloadHash      String?     @map("payload_hash")
  receivedAt       DateTime    @default(now()) @map("received_at") @db.Timestamptz(6)
  processingStatus String      @default("received") @map("processing_status")
  processingNotes  String?     @map("processing_notes")
  payment          Payment     @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId], map: "idx_payment_events_payment_id")
  @@index([receivedAt], map: "idx_payment_events_received_at")
  @@map("payment_events")
}

model DownloadEntitlement {
  id             String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId        String                   @map("order_id") @db.Uuid
  orderItemId    String                   @map("order_item_id") @db.Uuid
  appUserId      String?                  @map("app_user_id") @db.Uuid
  accessToken    String                   @unique @default(dbgenerated("gen_random_uuid()")) @map("access_token") @db.Uuid
  status         EntitlementStatus        @default(active)
  expiresAt      DateTime?                @map("expires_at") @db.Timestamptz(6)
  downloadLimit  Int?                     @map("download_limit")
  downloadCount  Int                      @default(0) @map("download_count")
  createdAt      DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  revokedAt      DateTime?                @map("revoked_at") @db.Timestamptz(6)
  order          Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem      OrderItem                @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  appUser        AppUser?                 @relation(fields: [appUserId], references: [id])
  downloadLogs   EntitlementDownloadLog[]

  @@index([orderId], map: "idx_entitlements_order_id")
  @@map("download_entitlements")
}

model EntitlementDownloadLog {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entitlementId String              @map("entitlement_id") @db.Uuid
  productAssetId String             @map("product_asset_id") @db.Uuid
  ipAddress     String?             @map("ip_address") @db.Inet
  userAgent     String?             @map("user_agent")
  downloadedAt  DateTime            @default(now()) @map("downloaded_at") @db.Timestamptz(6)
  entitlement   DownloadEntitlement @relation(fields: [entitlementId], references: [id], onDelete: Cascade)
  productAsset  ProductAsset        @relation(fields: [productAssetId], references: [id])

  @@index([entitlementId], map: "idx_entitlement_logs_entitlement_id")
  @@map("entitlement_download_logs")
}

model AdminAuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminUserId String   @map("admin_user_id") @db.Uuid
  actionType  String   @map("action_type")
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id") @db.Uuid
  beforeJson  Json?    @map("before_json") @db.JsonB
  afterJson   Json?    @map("after_json") @db.JsonB
  ipAddress   String?  @map("ip_address") @db.Inet
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  adminUser   AppUser  @relation("AdminAuditLogs", fields: [adminUserId], references: [id])

  @@map("admin_audit_logs")
}
